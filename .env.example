# Server
# Use development for local testing (relaxed env validation, dev logging)
NODE_ENV=development
PORT=5000
HOST=0.0.0.0

# AWS RDS PostgreSQL connection string
# Example: postgresql://username:password@your-rds-endpoint.region.rds.amazonaws.com:5432/solarvy
DATABASE_URL=

# Set to false only for local PostgreSQL without SSL
DATABASE_SSL=true

# Optional: max connections in the pool (default 10)
DATABASE_POOL_MAX=10

# Comma-separated allowed frontend origins (no trailing slash)
# Production frontend is hosted at https://solarvy.net
# Local Vite dev server:
FRONTEND_URL=https://solarvy.net,http://localhost:5173,http://127.0.0.1:5173

# Public URL of this API — set to your EC2 public IP or domain
# Local: http://localhost:5000
API_URL=http://localhost:5000

# Excel calculation engine
# Path to the client's master workbook (defaults to Backend/templates/solarvy-calculator.xlsx)
EXCEL_TEMPLATE_PATH=
# Temp dir for per-assessment workbook copies (defaults to OS temp dir)
EXCEL_TEMP_DIR=
# LibreOffice executable. Windows: C:\Program Files\LibreOffice\program\soffice.com
# Linux EC2: soffice. Run `npm run setup:local` on Windows to install.
# On Windows, if LibreOffice is missing but Microsoft Excel is installed, Excel COM
# is used automatically for local recalculation (set EXCEL_USE_COM=false to disable).
LIBREOFFICE_PATH=C:\Program Files\LibreOffice\program\soffice.com
EXCEL_USE_COM=
EXCEL_CALC_TIMEOUT_MS=120000

# AWS Textract (bill OCR). On EC2 prefer an IAM instance role instead of keys.
# When AWS is unavailable locally, Tesseract OCR is used automatically.
AWS_REGION=eu-west-1
# Force local OCR only (optional): BILL_OCR_FALLBACK=tesseract
